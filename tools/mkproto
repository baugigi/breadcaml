#!/bin/bash
[ -z "$1" ] || [ -z "$2" ] || [ -n "$3" ] && {
echo "1:'$1' 2:'$2' 3:'$3'"
cat <<END
Usage: mkproto TAG FILE

Read the given FILE (in ACME cross assembler format) and print on standard
output a list of dummy C prototypes for all user-defined primitives.

The output can be redirected to a .c file suitable to link the user-defined
primitives and the object code generated by the O64ml compiler.

The entrypoint line of each primitive must start with a global label followed
by a ";TAG" comment, with no characters but spaces o tabs between them. Spaces
and tabs are admitted between ';' and TAG too, as more than a single semicolon.

mkproto is part of The O64ml Project.
END
exit 1
}

sed -nE "s:^[ \t]*([_A-Za-z][_A-Za-z0-9]*)[ \t;]+$1[ \t]*$:void \1(){}:p" "$2"
