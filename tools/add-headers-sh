# Se non è stata passata una cartella come argomento, stampa i modelli
# disponibili; altrimenti controlla che la cartella esista
if [[ -z $1 ]]; then
    for I in ${!TITLE[@]}; do
	echo ""
	echo "vvv $I) ${TITLE[$I]}"
	echo "${HEADER[$I]}"
	echo "^^^ $I) FINE MODELLO"
	echo ""
    done | less
    exit 0
elif [[ ! -d $1 ]]; then
    echo "Errore: La cartella '$1' non esiste."
    exit 1
fi

DIR="$1"

# Selezione dell'header
echo "Quale header vuoi applicare ai file in '$DIR'?"
for I in ${!TITLE[@]}; do
    echo " $I) ${TITLE[$I]}"
done
read -p "Scegli un'opzione (1 ... ${#TITLE[@]}): " CHOICE

# Assegna lo header scelto
if [[ $CHOICE =~ ^[0-9]+ && -n ${TITLE[$CHOICE]} ]]; then
    echo "Applicazione di ${TITLE[$CHOICE]}..."
else
    echo "Scelta non valida. Uscita."
    exit 1
fi

# Trova tutti i file da elaborare nella directory e nelle sue subdirectory
# Usa eval per evitare l'espansione di * in FIND
eval "find \"\$DIR\" -type f \( ${FIND[$CHOICE]} \)" | while read -r FILE; do
    # Salta il file se nelle prime tre righe contiene già la firma
    # "Progetto O64ml / The O64ml Project"
    if grep -q -m 3 "$SIGNATURE" "$FILE"; then
        echo "Saltato (header già presente): $FILE"
    else
        TEMP_FILE=$(mktemp)
        echo "${HEADER[$CHOICE]}" > "$TEMP_FILE"
        echo "" >> "$TEMP_FILE"		# Riga vuota di separazione
        cat "$FILE" >> "$TEMP_FILE"
        mv "$TEMP_FILE" "$FILE"
        echo "Header inserito in: $FILE"
    fi
done

echo "Operazione completata!"
