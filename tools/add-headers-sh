if [[ "$1" = "--help" || "$1" = "-h" || -n "$2" ]]; then
    cat <<EOF
$0 [DIRECTORY]

Aggiunge gli header appropriati a tutti i file sorgenti OCaml o ACME
nella DIRECTORY indicata e nelle sue subdirectory.
Se DIRECTORY non è indicata, stampa i modelli di header disponibili.

EOF
    exit 0
fi

# Definizione degli header

DATE="21-Apr-2026"
SIGNATURE="Progetto O64ml / The O64ml Project"
COPYRIGHT="Copyright (C) $DATE Piero Furiesi"

TITLE[1]="Sorgenti OCaml - no terze parti (GPL v2)"
FIND[1]='-name "*.ml" -o -name "*.mli" -o -name "*.ml.template"'
HEADER[1]=$(cat <<EOF
(* ——————————————————————————————————————————————————————————————————————
