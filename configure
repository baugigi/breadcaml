# Check if stdout is a terminal and supports colours
if [ -t 1 ] && which tput > /dev/null 2>&1; then
    ncol=$(tput colors)
    if [ $? = 0 ] && [ -n "$ncol" ] && [ $ncol -ge 8 ]; then
        blk="$(tput setaf 0)"
        red="$(tput setaf 1)"
        grn="$(tput setaf 2)"
        yel="$(tput setaf 3)"
        blu="$(tput setaf 4)"
        mag="$(tput setaf 5)"
        cyn="$(tput setaf 6)"
        wht="$(tput setaf 7)"
        bld="$(tput bold)"
        und="$(tput smul)"
	rev="$(tput rev)"
        nrm="$(tput sgr0)"
    fi
fi

OK="${bld}${grn}ok,${nrm}"
WRN="${und}${bld}${yel}/!\\${nrm}"
ERR="${bld}${red}KO:${nrm}"

# Function: exit printing a failure message
failwith () {
    echo "${bld}${red}Configuration failed:${nrm} $@." 1>&2
    exit 1
}

# Function: show an help message about this script
show_help () {
    cat <<__END__
Usage: $0 [ OPTIONS... ]
  -b, --bindir <dir>  Where to install the o64ml program,
                      default: $PREFIX/bin
  -l, --libdir <dir>  Where to install O64ml libraries,
                      default: $PREFIX/lib/o64ml
  -m, --mandir <dir>  Where to install manual pages,
                      default: $PREFIX/man
  -p, --prefix <dir>  Shortcut for
		      -b <dir>/bin -l <dir>/lib/o64ml -m <dir>/man
  -y, --yes           Assume 'yes' as answer to "Install ACME?" prompt

  -h, --help          Show this text.
__END__
    exit 0
}

# Set default installation paths
PREFIX=${OPAM_SWITCH_PREFIX:-~}
BINDIR=$PREFIX/bin
LIBDIR=$PREFIX/lib/o64ml
MANDIR=$PREFIX/man

# Set section for Stdlib manpages
MAN3EXT=3o64

# Parse command-line options and update installation paths accordingly
while [ $# -ne 0 ]; do
    case "$1" in
	-b | --bindir)
	    shift
	    BINDIR="$1"
	    ;;
	-l | --libdir)
	    shift
	    LIBDIR="$1"
	    ;;
	-m | --mandir)
	    shift
	    MANDIR="$1"
	    ;;
	-p | --prefix)
	    shift
	    PREFIX="$1"
	    BINDIR="$PREFIX/bin"
	    LIBDIR="$PREFIX/lib/o64ml"
	    MANDIR="$PREFIX/man"
	    ;;
	-y | --yes)
	    YN=Y
	    ;;
	-h | --help)
	    show_help
	    ;;
	*)
	    failwith "unknown option '$1'"
    esac
    shift
done

# Ensure all needed commands are available
echo "${bld}Checking available commands...${nrm}"
MISSING=""
for CMD in ar bunzip2 cat chmod cp cut date head install make mkdir mktemp \
	   ocaml ocamlc ocamldoc ocamlopt realpath rm rmdir sed sort tar; do
    CHK="$(type $CMD 2> /dev/null)"
    if [ $? = 0 ]; then
	echo " $OK $CHK"
    else
	echo " $ERR $CMD not found"
	MISSING="${MISSING:+$MISSING, }$CMD"
    fi
done
echo -e "${bld}... Done.${nrm}\n"
[ "$MISSING" ] && \
    failwith "command(s) $MISSING not present, or not in search PATH"

BINDIR="$(realpath -m "$BINDIR")"
LIBDIR="$(realpath -m "$LIBDIR")"
MANDIR="$(realpath -m "$MANDIR")"

# Get the O64ml version
VERSION="$(< VERSION)"

# Locate OCaml compilers and tools
OCAMLC="$(which ocamlc.opt 2> /dev/null || which ocamlc)"
OCAMLOPT="$(which ocamlopt.opt 2> /dev/null || which ocamlopt)"
OCAMLDOC="$(which ocamldoc.opt 2> /dev/null || which ocamldoc)"
OCAMLSTDLIB=$($OCAMLC -where)

# Check if the installed ACME release is 0.97 ("Zem"), 16 Nov 2025 or newer
echo "${bld}Checking for ACME crossassembler...${nrm}"
ACME="$BINDIR/acme"
[ -x "$ACME" ] || ACME="$(which acme 2> /dev/null)"
if [ "$ACME" ] && {
       ACME_DATE=$("$ACME" --version | head -n 1 | cut -d',' -f 3)
       [ $(date -d"$ACME_DATE" +%Y%m%d 2> /dev/null) -ge 20251116 ]
   }; then
    echo " $OK O64ml will use $ACME"
else
    # Install ACME in $BINDIR
    echo " $WRN ACME is not present or is out of date."
    echo " This script can install a version suitable for O64ml in"
    echo " ${bld}$BINDIR${nrm}"
    echo -n " Do you want to proceed? (Y/n) "
    [ "$YN" = "Y" ] && echo "Yes (-y specified)" || read YN
    [[ -z "$YN" || "$YN" == [yY] || "$YN" == [yY][eE][sS] ]] \
	|| failwith "aborted by user"
    echo " Installing..."
    ACME_TMP=$(mktemp -d)
    tar -xjf acme*.tar.bz2 --one-top-level=$ACME_TMP --strip-components=1
    make --quiet -C $ACME_TMP/src BINDIR="$BINDIR" install 2> /dev/null \
        || failwith "ACME installation failed"
    rm -fr $ACME_TMP
    echo " $OK ACME installation successful."
    ACME="$BINDIR/acme"
fi
echo -e "${bld}... Done.${nrm}\n"

# Export the configuration data needed by 'make'
cat > etc/Makefile.conf <<__END__
ACME = $ACME
BINDIR = $BINDIR
LIBDIR = $LIBDIR
MAN1DIR = $MANDIR/man1
MAN3DIR = $MANDIR/man3
MAN3EXT = $MAN3EXT
OCAMLC_UNSAFE = $OCAMLC
OCAMLC = $OCAMLC -safe-string -strict-formats -strict-sequence
OCAMLDOC = $OCAMLDOC
OCAMLOPT = $OCAMLOPT -safe-string -strict-formats -strict-sequence
OCAMLSTDLIB = $OCAMLSTDLIB
VERSION = $VERSION
__END__

# Let the user know the result of the configuration
cat <<__END__
${bld}O64ml ver. $VERSION configured successfully as follows:${nrm}
  BINDIR = ${cyn}$BINDIR${nrm}
  LIBDIR = ${cyn}$LIBDIR${nrm}
  MANDIR = ${cyn}$MANDIR${nrm}  (man section: ${cyn}$MAN3EXT${nrm})

For info on how to change this configuration, type:
  ${bld}$0 --help${nrm}

To build the O64ml system, enter:
  ${bld}make${nrm}
then you can install it with:
  ${bld}make install${nrm}
After installation, you can clean the source directory tree with:
  ${bld}make clean${nrm}

To uninstall all O64ml files, type:
  ${bld}make uninstall${nrm}
__END__
