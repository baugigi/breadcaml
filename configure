shopt -s extglob


# Check if stdout is a terminal and supports colours
if [[ -t 1 ]] && which tput > /dev/null 2>&1; then
    ncol=$(tput colors)
    if [[ $? = 0 && -n $ncol && $ncol -ge 8 ]]; then
        blk="$(tput setaf 0)"
        red="$(tput setaf 1)"
        grn="$(tput setaf 2)"
        yel="$(tput setaf 3)"
        blu="$(tput setaf 4)"
        mag="$(tput setaf 5)"
        cyn="$(tput setaf 6)"
        wht="$(tput setaf 7)"
        bld="$(tput bold)"
        und="$(tput smul)"
        rev="$(tput rev)"
        nrm="$(tput sgr0)"
    fi
fi


# ok/warning/error strings
OK="${bld}${grn} ok,${nrm}"
WRN="${und}${bld}${yel} /!\\${nrm}"
ERR="${bld}${red} KO:${nrm}"


#### Shell functions

# Show an help message about this script
show_help () {
    cat <<__END__
Usage: $0 [ OPTIONS... ]
  -b, --bindir <dir>  Target directory for Breadcaml binaries
                      default: $PREFIX/bin
  -l, --libdir <dir>  Target directory for the BreadCaml Stdlib files
                      default: $PREFIX/lib/breadcaml
  -m, --mandir <dir>  Target directory for manual pages
                      default: $PREFIX/man
  -p, --prefix <dir>  Shortcut for
                      -b <dir>/bin -l <dir>/lib/breadcaml -m <dir>/man
  -y, --yes           Automatically accept the ACME installation prompt

  -h, --help          Show this text.
__END__
    exit 0
}


# Exit printing a failure message
failwith () {
    echo "${bld}${red}Configuration failed:${nrm} $@." 1>&2
    exit 1
}

####


# Default installation paths
PREFIX=${OPAM_SWITCH_PREFIX:-~}
BINDIR=$PREFIX/bin
LIBDIR=$PREFIX/lib/breadcaml
MANDIR=$PREFIX/man
MAN3EXT=3bc


# Parse command-line options and update installation paths accordingly
while [[ $# -ne 0 ]]; do
    case "$1" in
        -b | --bindir | -l | --libdir | -m | --mandir)
	    [[ $DIROPT == @(-p|--prefix) ]] \
		&& failwith "'$1' and '$DIROPT' options are incompatible"
	    DIROPT="$1"
            shift
	    case "$DIROPT" in
		-b | --bindir)
		    BINDIR="$1"
		    ;;
		-l | --libdir)
		    LIBDIR="$1"
		    ;;
		-m | --mandir)
		    MANDIR="$1"
		    ;;
	    esac
	    ;;
        -p | --prefix)
	    [[ $DIROPT == @(-b|--bindir|-l|--libdir|-m|--mandir) ]] \
		&& failwith "'$1' and '$DIROPT' options are incompatible"
	    DIROPT="$1"
            shift
            PREFIX="$1"
            BINDIR="$PREFIX/bin"
            LIBDIR="$PREFIX/lib/breadcaml"
            MANDIR="$PREFIX/man"
            ;;
        -y | --yes)
            ACME_INSTALL='Y'
            ;;
        -h | --help)
            show_help
            ;;
        *)
            failwith "unknown option '$1'"
    esac
    shift
done


# Ensure all needed commands are available
echo "${bld}Checking for installed commands...${nrm}"
for CMD in ar bunzip2 make tar ocamlc.opt ocamlopt.opt ocamldoc.opt; do
    if CHK=$(which $CMD 2> /dev/null); then
        echo "$OK $CMD is ${cyn}$CHK${nrm}"
    elif [[ $CMD == *.opt ]] && CHK=$(which ${CMD%.opt} 2> /dev/null); then
        echo "$WRN $CMD not found, but ${CMD%.opt} is ${cyn}$CHK${nrm}"
    else
        echo "$ERR $CMD not found"
        MISSING="${MISSING:+$MISSING, }$CMD"
    fi
done
echo -e "${bld}... Done.${nrm}\n"
[[ $MISSING ]] \
    && failwith "command(s) $MISSING not present, or not in search PATH"


# Check the OCaml version (ok if 4.14.0 <= version < 5.0.0)
echo "${bld}Checking OCaml bytecode compiler version...${nrm}"
OCAMLC="$(which ocamlc.opt 2>/dev/null || which ocamlc)"
IFS='.' read -r MAJOR MINOR PATCH < <($OCAMLC -vnum)
if (( OCAMLC_STATUS=(MAJOR == 4 && MINOR >= 14) )); then
    echo "$OK ocamlc version is $MAJOR.$MINOR.$PATCH"
else
    echo "$ERR incompatible ocamlc version: $MAJOR.$MINOR.$PATCH"
fi
echo -e "${bld}... Done.${nrm}\n"
(( OCAMLC_STATUS )) \
    || failwith "ocamlc version must be >= 4.14.0 and < 5.0.0"


# Check if ACME is obsolete or not installed
# We need the release 0.97 ("Zem"), 16 Nov 2025 or newer
echo "${bld}Checking for ACME cross-assembler...${nrm}"
ACME="$BINDIR/acme"
[[ -x $ACME ]] || ACME="$(which acme 2> /dev/null)"
if [[ $ACME ]]; then
    IFS=',' read -r UNUSED ACME_REL ACME_DATE < <($ACME --version)
    if (( $(date -d"$ACME_DATE" +%Y%m%d 2> /dev/null) >= 20251116 )); then
        echo "$OK found ${cyn}$ACME${nrm} $ACME_REL,$ACME_DATE"
	ACME_STATUS=0
    else
        echo "$WRN found incompatible version $ACME $ACME_REL,$ACME_DATE"
	ACME_STATUS=1
    fi
else
    echo "$WRN ACME not installed, or not in search PATH or $BINDIR."
    ACME_STATUS=2
fi
echo -e "${bld}... Done.${nrm}\n"


# IF ACME is obsolete or missing, install it in BINDIR
if (( ACME_STATUS > 0 )); then
    if [[ -z $ACME_INSTALL ]]; then
        echo "This script can install a BreadCaml-compatible\
              version of ACME in ${bld}$BINDIR${nrm}."
        if (( ACME_STATUS == 1 )); then
            echo -n " The existing '$ACME' command will be "
            [[ $ACME == $BINDIR/acme ]] && echo "renamed." || echo "retained."
        fi
        echo -n " Do you want to proceed? (Y/N) "
        read ACME_INSTALL
    fi
    [[ $ACME_INSTALL == @([yY]|[yY][eE][sS]) ]] || failwith "aborted by user"
    echo "${bld}Installing ACME...${nrm}"
    ACME_TMP=$(mktemp -d)
    (
        if [[ $ACME == $BINDIR/acme ]]; then
	    ACME_OLD=$(mktemp "$BINDIR/acme.oldXXX")
            cp "$ACME" "$ACME_OLD"
        fi
        tar -xjf acme*.tar.bz2 --one-top-level="$ACME_TMP" --strip-components=1
        make -C "$ACME_TMP/src" BINDIR="$BINDIR" install
        rm -fr "$ACME_TMP"
    )
    if [[ $? = 0 ]]; then
        echo -e "${bld}... Done.${nrm}\n"
        [[ $ACME_OLD ]] && echo "The old command has been renamed '$ACME_OLD'."
    else
        rm -fr "$ACME_TMP" "$ACME_OLD"
        failwith "ACME installation failed"
    fi
fi

# Set BreadCaml environment
BINDIR="$(realpath -m "$BINDIR")"
LIBDIR="$(realpath -m "$LIBDIR")"
MANDIR="$(realpath -m "$MANDIR")"
OCAMLDOC="$(which ocamldoc.doc 2>/dev/null || which ocamldoc)"
OCAMLOPT="$(which ocamlopt.opt 2>/dev/null || which ocamlopt)"
OCAMLSTDLIB=$($OCAMLC -where)
VERSION="$(< VERSION)"

# Export the configuration data needed by 'make'
cat > etc/Makefile.conf <<__END__
ACME = $ACME
BINDIR = $BINDIR
LIBDIR = $LIBDIR
MAN1DIR = $MANDIR/man1
MAN3DIR = $MANDIR/man3
MAN3EXT = $MAN3EXT
OCAMLC_UNSAFE = $OCAMLC
OCAMLC = $OCAMLC -safe-string -strict-formats -strict-sequence
OCAMLDOC = $OCAMLDOC
OCAMLOPT = $OCAMLOPT -safe-string -strict-formats -strict-sequence
OCAMLSTDLIB = $OCAMLSTDLIB
VERSION = $VERSION
__END__

# Show the result of the configuration
cat <<__END__
${bld}BreadCaml version $VERSION configured successfully as follows:${nrm}
  BINDIR = ${cyn}$BINDIR${nrm}
  LIBDIR = ${cyn}$LIBDIR${nrm}
  MANDIR = ${cyn}$MANDIR${nrm}  (Stdlib manpage section: ${cyn}$MAN3EXT${nrm})

${bld}**${nrm} For info on how to change this configuration, type: ${bld}$0 --help${nrm}
${bld}**${nrm} To build the BreadCaml system, enter: ${bld}make${nrm}
      then you can install it with: ${bld}make install${nrm}
      At end, clean the source directory tree with: ${bld}make clean${nrm}
${bld}**${nrm} To uninstall BreadCaml, enter: ${bld}make uninstall${nrm}

Happy BreadCamling on your Commodore 64!
__END__
