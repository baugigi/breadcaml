#!/bin/bash
cd "$(dirname $0)/.."
[ -f VERSION ] || { echo "I'm lost!"; exit 1; }
[ -f CHANGES ] || touch CHANGES
VERSION=$(< VERSION)
DEST=o64ml-$VERSION_$(date +"%Y%m%d_%H%M").tar.bz2
echo "Inserire una nota per la distribuzione $DEST:"
echo "(ctrl-D per finire)"
{
    echo "*** $DEST"
    cat /dev/stdin
    echo -e "\n"
    cat CHANGES
} > CHANGES.new
mv CHANGES.new CHANGES
tar -cjf "dist/$DEST" --exclude="dist/*.tar.bz2" .
echo "** Distribution $DEST created successfully **"
